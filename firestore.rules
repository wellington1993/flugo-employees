rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /staffs/{staffId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'department', 'status', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.email is string
        && request.resource.data.email.matches('.*@.*\\..*')
        && request.resource.data.department in ['Design', 'TI', 'Marketing', 'Produto', 'RH', 'Financeiro', 'Comercial', 'Operações']
        && request.resource.data.status in ['ACTIVE', 'INACTIVE']
        && request.resource.data.createdAt is number;
      allow update, delete: if false;
    }
  }
}
